<header class="principal">
  <h1>HaiVintage</h1>
  <nav id="meniu-principal">

    
    <input type="checkbox" id="menu-toggle" class="menu-toggle" hidden>

    <label for="menu-toggle" class="hamburger-btn" aria-label="Deschide meniul">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Обёртка: фон + меню растягиваются вместе -->
    <div class="menu-wrapper">
      <ul id="lista-meniu">

        <li class="acasa has-submenu">
          <input type="checkbox" id="sub-acasa" class="sub-toggle" hidden>
          <!-- Десктоп: ссылка -->
          <a href="/index" class="menu-link">
            <i class="fa-solid fa-house"></i>
            <span>Acasă ▾</span>
          </a>
          <!-- Мобильный: label-триггер -->
          <label for="sub-acasa" class="menu-trigger">
            <i class="fa-solid fa-house"></i>
            <span>Acasă ▾</span>
          </label>
          <ul>
            <li><a href="#prezentare">Despre</a></li>
            <li><a href="#evenimente">Evenimente</a></li>
            <li><a href="#galerie">Galerie</a></li>
            <li><a href="#oferte">Produse</a></li>
            <li><a href="#video">Video</a></li>
          </ul>
        </li>

        <li class="has-submenu">
          <input type="checkbox" id="sub-colec" class="sub-toggle" hidden>
          <!-- Десктоп: кнопка -->
          <button class="btn-submeniu menu-link">
            <i class="fa-solid fa-layer-group"></i>
            <span>Colecții ▾</span>
          </button>
     
          <label for="sub-colec" class="menu-trigger">
            <i class="fa-solid fa-layer-group"></i>
            <span>Colecții ▾</span>
          </label>
          <ul>
            <li><a href="/dama">Haine damă</a></li>
            <li><a href="/barbati">Haine bărbați</a></li>
            <li><a href="/accesorii">Accesorii</a></li>
          </ul>
        </li>

        <li class="has-submenu">
          <input type="checkbox" id="sub-galerii" class="sub-toggle" hidden>
          <button class="btn-submeniu menu-link">
            <i class="fa-solid fa-images"></i>
            <span>Galerii ▾</span>
          </button>
          <label for="sub-galerii" class="menu-trigger">
            <i class="fa-solid fa-images"></i>
            <span>Galerii ▾</span>
          </label>
          <ul>
            <li><a href="/galerie">Galerie Statică</a></li>
            <li><a href="/galerie-dinamica">Galerie Dinamică</a></li>
          </ul>
        </li>

        <li class="has-submenu">
          <input type="checkbox" id="sub-produse" class="sub-toggle" hidden>
          <button class="btn-submeniu menu-link">
            <i class="fa-solid fa-tag"></i>
            <span>Produse ▾</span>
          </button>
          <label for="sub-produse" class="menu-trigger">
            <i class="fa-solid fa-tag"></i>
            <span>Produse ▾</span>
          </label>
          <ul>
            <li><a href="/produse">Toate</a></li>
            <% if (locals.categoriiProduse && categoriiProduse.length > 0) { %>
              <% categoriiProduse.forEach(cat => { %>
                <li>
                  <a href="/produse?categorie=<%= cat %>"
                     style="text-transform:capitalize"><%= cat %></a>
                </li>
              <% }) %>
            <% } %>
          </ul>
        </li>

        <li>
          <a href="/despre">
            <i class="fa-solid fa-circle-info"></i>
            <span>Despre</span>
          </a>
        </li>

        <li>
          <a href="/blog">
            <i class="fa-solid fa-pen"></i>
            <span>Blog</span>
          </a>
        </li>

        <li>
          <a href="/contact">
            <i class="fa-solid fa-envelope"></i>
            <span>Contact</span>
          </a>
        </li>

      </ul>
    </div>

    <!-- Tema selector (Bonus 2 / light-dark mandatory) -->
    <div class="tema-selector">
      <select id="select-tema" class="form-select form-select-sm" title="Schimbă tema">
        <option value="light">☀️ Light</option>
        <option value="dark">🌙 Dark</option>
        <option value="sepia">📜 Sepia</option>
      </select>
    </div>

  </nav>
</header>
<script>
(function () {
    const sel = document.getElementById('select-tema');
    if (!sel) return;
    const saved = localStorage.getItem('tema') || 'light';
    sel.value = saved;
    sel.addEventListener('change', function () {
        const t = this.value;
        localStorage.setItem('tema', t);
        document.documentElement.setAttribute('data-tema', t);
    });
})();
</script>